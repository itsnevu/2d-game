# === AI / SOVA Assistant ===
# OpenAI is REQUIRED for Whisper (speech-to-speech). Also used for SOVA if VITE_AI_PROVIDER=openai
OPENAI_API_KEY=
# For SOVA responses when using Gemini
GEMINI_API_KEY=
# For SOVA responses when using Grok (default)
GROK_API_KEY=
# AI provider for SOVA: openai | grok | gemini
VITE_AI_PROVIDER=grok

# === Local dev ports ===
VITE_KOKORO_BASE_URL=http://localhost:8001

# === Auth + Spacetime backends (optional; see README Client Configuration) ===
# Run Vite locally but use production Railway auth + Maincloud (faster local assets):
# VITE_USE_PRODUCTION_BACKENDS=true
# Overrides (highest precedence):
# VITE_AUTH_SERVER_URL=https://broth-and-bullets-production.up.railway.app
# VITE_SPACETIME_WS_URL=wss://maincloud.spacetimedb.com
# VITE_SPACETIME_DATABASE=broth-bullets

# === Auth (optional - only for password reset emails) ===
RESEND_API_KEY=
